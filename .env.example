# ============================================================
# Ideago — Environment Configuration (copy to .env)
# ============================================================

# ---- Shared ----
NODE_ENV=development
APP_NAME=Ideago
APP_URL=http://localhost:5181
API_URL=http://localhost:3003
CORS_ORIGIN=http://localhost:5173,http://localhost:5180,http://localhost:5181

# ---- Database (PostgreSQL) ----
POSTGRES_USER=ideago
POSTGRES_PASSWORD=ideago
POSTGRES_DB=ideago
POSTGRES_HOST=localhost
# Non-default host port to avoid clashing with a local Postgres install.
POSTGRES_PORT=55433
DATABASE_URL=postgresql://ideago:ideago@localhost:55433/ideago?schema=public

# ---- Redis (optional caching/sessions) ----
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_URL=redis://localhost:6380

# ---- JWT ----
JWT_ACCESS_SECRET=change_me_access_secret_dev_only
JWT_ACCESS_TTL=900s
JWT_REFRESH_SECRET=change_me_refresh_secret_dev_only
JWT_REFRESH_TTL=7d

# ---- AI Provider ----
# provider: mock | openai | anthropic | gemini
# For real AI Copilot answers, set AI_PROVIDER=gemini and add your Google AI Studio key.
# Keys from AI Studio may use the newer AQ. prefix (auth keys) or legacy AIza prefix.
AI_PROVIDER=gemini
AI_MODEL=gemini-1.5-flash
AI_FALLBACK_TO_MOCK=false
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=your_google_ai_studio_key_here

# ---- Mail (Mailhog in dev) ----
MAIL_HOST=localhost
MAIL_PORT=1026
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM="Ideago <no-reply@ideago.com>"

# ---- Seed admin / demo ----
SEED_ADMIN_EMAIL=admin@ideago.com
SEED_ADMIN_PASSWORD=Admin123!
SEED_FOUNDER_EMAIL=founder@ideago.com
SEED_FOUNDER_PASSWORD=Founder123!

# ---- Frontend (Vite, prefixed VITE_) ----
VITE_API_URL=http://localhost:3003
VITE_APP_NAME=Ideago
